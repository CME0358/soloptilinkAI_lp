{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "404.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404,
      "headers": {
        "Cache-Control": "no-store, max-age=0"
      }
    }
  ]
}
